{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the authenticated user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "GeneratedImage": {
      "title": "Generated Image",
      "description": "History of images generated by the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "prompt": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "prompt", "imageUrl", "createdAt"]
    },
    "GeneratedGame": {
      "title": "Generated Game",
      "description": "History of games generated by the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "prompt": { "type": "string" },
        "gameData": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "prompt", "gameData", "createdAt"]
    },
    "RPGProgress": {
      "title": "RPG Game Progress",
      "description": "Saved state for the RPG game.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "gameId": { "type": "string" },
        "character": { "type": "object" },
        "position": { "type": "object" },
        "defeatedMonsters": { "type": "number" },
        "inventory": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "gameId", "character", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/users/{userId}/images/{imageId}": {
      "schema": "GeneratedImage",
      "description": "Images generated by a specific user"
    },
    "/users/{userId}/games/{gameId}": {
      "schema": "GeneratedGame",
      "description": "Games generated by a specific user"
    },
    "/users/{userId}/rpg_progress/{gameId}": {
      "schema": "RPGProgress",
      "description": "Saved progress for RPG games"
    }
  }
}
